[user]
	name = Alex Trotta
	email = ahajha@gmail.com
[branch "main"]
	pushRemote = NOPE
[init]
	defaultBranch = main
[pile]
	cleanupRemoteOnSubmitFailure = true
[pull]
	rebase = true
[alias]
	co = checkout
	com = checkout main
	cp = cherry-pick
	cpr = "!f() { git cherry-pick \"$1\" && git submitpr; }; f"
	cprm = "!f() { git cherry-pick \"$1\" && git submitpr --merge-squash; }; f"
	pl = pull
	pom = push origin main
	pr = submitpr
	prd = submitpr --draft
	prm = submitpr --merge-squash
	pu = push
	up = "!f() { git updatepr HEAD~${1:-1}; }; f"
[rerere]
	enabled = true
	autoupdate = true
[advice]
	skippedCherryPicks = false
[rebase]
	autoStash = true
[diff]
    tool = vscode
[merge]
    tool = vscode
[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE
[mergetool "vscode"]
    cmd = code --wait $MERGED
